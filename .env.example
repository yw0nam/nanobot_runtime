# ── TTS (Text-to-Speech) ──────────────────────────────────────────────────────

# TTS 파이프라인 전체 활성화 여부. 0으로 설정하면 TTS 훅이 등록되지 않음.
TTS_ENABLED=1

# Irodori TTS 서버 주소.
TTS_URL=http://192.168.0.41:8091

# TTS 합성 시 사용할 레퍼런스 오디오 ID. 미설정 시 서버 기본값 사용.
# TTS_REF_AUDIO=

# 감정 → 음성 파라미터 매핑 규칙 YAML 경로.
# 미설정 시 <workspace>/resources/tts_rules.yml 을 사용.
# TTS_RULES_PATH=./resources/tts_rules.yml

# 채널별 TTS 모드(활성/비활성/텍스트 전용 등) 설정 YAML 경로.
# 미설정 시 <workspace>/resources/tts_channel_modes.yml 을 사용.
# TTS_MODES_PATH=./resources/tts_channel_modes.yml

# TTS 청크 배리어 대기 타임아웃(초). 이 시간 초과 시 해당 청크 TTS를 포기하고 진행.
TTS_BARRIER_TIMEOUT=30

# ── LTM (Long-Term Memory) ────────────────────────────────────────────────────

# LTM에 기록될 사용자 ID.
LTM_USER_ID=sangjun

# LTM에 기록될 에이전트 ID.
LTM_AGENT_ID=yuri

# LTM MCP 서버 엔드포인트 URL.
LTM_URL=http://127.0.0.1:7777/mcp/

# LTM 검색 시 반환할 최대 메모리 개수.
LTM_TOP_K=5

# ── Idle (Proactive 발화) ─────────────────────────────────────────────────────

# Idle 시스템 활성화 여부. 0으로 설정하면 proactive 발화가 완전히 비활성화됨.
IDLE_ENABLED=1

# 마지막 상호작용 이후 idle로 판정하기까지의 대기 시간(초).
IDLE_TIMEOUT_S=300

# idle 발화 후 다음 발화까지의 최소 대기 시간(초). 연속 발화 방지.
IDLE_COOLDOWN_S=900

# idle 상태를 확인하는 스캔 주기(초).
IDLE_SCAN_INTERVAL_S=30

# 서비스 시작 직후 idle 판정을 유예하는 시간(초). 초기 메시지 폭탄 방지.
IDLE_STARTUP_GRACE_S=120

# idle 발화를 전송할 채널 목록. 콤마로 구분.
IDLE_CHANNELS=desktop_mate

# 정숙 시간 시작(HH:MM). 이 시간대에는 idle 발화를 하지 않음.
IDLE_QUIET_START=02:00

# 정숙 시간 종료(HH:MM). IDLE_QUIET_START와 함께 비워두면 정숙 시간 비활성화.
IDLE_QUIET_END=07:00

# 정숙 시간 판정에 사용할 타임존.
IDLE_TIMEZONE=Asia/Tokyo

# ── 워크스페이스 / 설정 파일 ──────────────────────────────────────────────────

# nanobot 설정 파일(nanobot.json) 경로.
NANOBOT_CONFIG=./nanobot.json

# 워크스페이스 루트 경로. nanobot이 리소스를 탐색할 기준 디렉터리.
NANOBOT_WORKSPACE=.

# ── 로깅 ─────────────────────────────────────────────────────────────────────

# 로그 파일이 저장될 디렉터리 경로.
LOG_DIR=logs
